<div class="testimonials-section" style="padding: 80px 20px; background-color: {{ section.settings.bg_color }};">
  <div class="container" style="max-width: 1200px; margin: 0 auto;">
    
    <div style="text-align: center; margin-bottom: 50px;">
      <h2 style="font-size: 36px; color: {{ section.settings.title_color }}; margin-bottom: 12px; font-weight: 600;">
        {{ section.settings.title | default: "⭐ Avis de nos frères et sœurs" }}
      </h2>
      <p style="font-size: 18px; color: {{ section.settings.subtitle_color }}; opacity: 0.8;">
        {{ section.settings.subtitle | default: "Plus de 2000 clients satisfaits font confiance à Rawdine" }}
      </p>
    </div>

    <div class="testimonials-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
      {% for block in section.blocks %}
        <div class="testimonial-card" style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
          
          <div class="stars" style="color: #D4AF37; font-size: 20px; margin-bottom: 16px;">
            {% for i in (1..block.settings.rating) %}⭐{% endfor %}
          </div>

          <p style="font-size: 16px; line-height: 1.7; color: #2C2C2C; margin-bottom: 20px; font-style: italic;">
            “{{ block.settings.text }}”
          </p>

          <div style="display: flex; align-items: center; gap: 12px;">
            {% if block.settings.avatar %}
              <img src="{{ block.settings.avatar | img_url: '50x50' }}" alt="{{ block.settings.author }}" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover;">
            {% else %}
              <div style="width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg, #00A651, #D4AF37); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 20px;">
                {{ block.settings.author | slice: 0 }}
              </div>
            {% endif %}

            <div>
              <p style="font-weight: 600; color: #2C2C2C; margin: 0; font-size: 16px;">
                {{ block.settings.author }}
              </p>
              <p style="font-size: 14px; color: #666; margin: 0;">
                📍 {{ block.settings.location }}
              </p>
            </div>
          </div>

        </div>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Témoignages Clients",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "⭐ Avis de nos frères et sœurs"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Plus de 2000 clients satisfaits font confiance à Rawdine"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur fond",
      "default": "#FDFCF8"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titre",
      "default": "#2C2C2C"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Couleur sous-titre",
      "default": "#666666"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Témoignage",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte témoignage"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Nom client"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Ville"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Note (étoiles)",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Photo client (optionnel)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Témoignages Rawdine",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "text": "Mon tapis Rawdah est magnifique ! La qualité est exceptionnelle.",
            "author": "Fatima L.",
            "location": "Paris",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
