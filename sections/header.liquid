{% comment %}
  HEADER - Navigation principale
{% endcomment %}

<header class="header" data-section-id="{{ section.id }}" data-section-type="header">
  <div class="container">
    <div class="header-inner">
      
      <!-- Logo -->
      <div class="header-logo">
        <a href="{{ routes.root_url }}" class="logo-link">
          {% if section.settings.logo %}
            <img src="{{ section.settings.logo | img_url: '200x' }}" 
                 alt="{{ shop.name }}" 
                 class="logo-image">
          {% else %}
            <h1 class="logo-text">🕌 {{ shop.name }}</h1>
          {% endif %}
        </a>
      </div>
      
      <!-- Navigation -->
      <nav class="header-nav" role="navigation">
        <ul class="nav-list">
          <li class="nav-item">
            <a href="{{ routes.root_url }}" class="nav-link">🏠 Accueil</a>
          </li>
          <li class="nav-item">
            <a href="{{ routes.collections_url }}" class="nav-link">🛍️ Boutique</a>
          </li>
          <li class="nav-item">
            <a href="/pages/notre-histoire" class="nav-link">💚 À propos</a>
          </li>
          <li class="nav-item">
            <a href="/blogs/guides" class="nav-link">📖 Blog</a>
          </li>
          <li class="nav-item">
            <a href="/pages/contact" class="nav-link">📧 Contact</a>
          </li>
        </ul>
      </nav>
      
      <!-- Actions -->
      <div class="header-actions">
        <!-- Search -->
        <a href="/search" class="header-action" aria-label="Rechercher">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"/>
            <path d="M13 13L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </a>
        
        <!-- Account -->
        <a href="{{ routes.account_url }}" class="header-action" aria-label="Compte">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="6" r="4" stroke="currentColor" stroke-width="2"/>
            <path d="M4 18C4 14.6863 6.68629 12 10 12C13.3137 12 16 14.6863 16 18" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
        
        <!-- Cart -->
        <button class="header-action header-cart" data-cart-open aria-label="Panier">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 3H5L6 14H16L18 6H7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <circle cx="8" cy="18" r="1" fill="currentColor"/>
            <circle cx="14" cy="18" r="1" fill="currentColor"/>
          </svg>
          <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
        </button>
      </div>
      
    </div>
  </div>
</header>

<style>
.header {
  background-color: var(--blanc-pur);
  border-bottom: 1px solid var(--gris-serein);
  padding: var(--spacing-md) 0;
  position: sticky;
  top: 0;
  z-index: 100;
  transition: box-shadow var(--transition-normal);
}

.header--sticky {
  box-shadow: var(--shadow-md);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-lg);
}

.logo-text {
  font-family: var(--font-titre);
  font-size: 1.5rem;
  margin: 0;
  color: var(--vert-medine);
}

.logo-image {
  height: 50px;
  width: auto;
}

.nav-list {
  display: flex;
  gap: var(--spacing-lg);
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav-link {
  font-family: var(--font-sous-titre);
  font-weight: 500;
  color: var(--noir-nuit);
  transition: color var(--transition-fast);
}

.nav-link:hover {
  color: var(--vert-medine);
}

.header-actions {
  display: flex;
  gap: var(--spacing-md);
  align-items: center;
}

.header-action {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--noir-nuit);
  position: relative;
  padding: var(--spacing-xs);
  transition: color var(--transition-fast);
}

.header-action:hover {
  color: var(--vert-medine);
}

.cart-count {
  position: absolute;
  top: -5px;
  right: -5px;
  background-color: var(--bordeaux-tapis);
  color: var(--blanc-pur);
  font-size: 0.75rem;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: 10px;
  min-width: 18px;
  text-align: center;
}

@media (max-width: 768px) {
  .header-nav {
    display: none;
  }
}
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}